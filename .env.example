# =============================================================================
# Shopware 6 Admin API
# =============================================================================
# URL ohne trailing slash
SHOPWARE_URL=https://your-shop.example.com

# Integration anlegen unter: Admin > Settings > System > Integrations
# Berechtigungen: product (read/write), category (read), property_group (read),
#                 manufacturer (read), tax (read), currency (read), tag (write),
#                 sales_channel (read)
SHOPWARE_CLIENT_ID=SWIA...
SHOPWARE_CLIENT_SECRET=...

# =============================================================================
# Shop-spezifische IDs (PFLICHT)
# =============================================================================
# Standard-Steuersatz ID (Admin > Settings > Tax)
# Beispiel: Kleinunternehmer 0% oder Standard 19%
SHOPWARE_DEFAULT_TAX_ID=your-tax-id-here

# Steuersatz in Prozent (0 fuer Kleinunternehmer, 19 fuer Standard)
SHOPWARE_DEFAULT_TAX_RATE=0

# Standard-Verkaufskanal ID (Admin > Sales Channels)
SHOPWARE_DEFAULT_SALES_CHANNEL_ID=your-sales-channel-id-here

# =============================================================================
# Optionale Shop IDs
# =============================================================================
# Standard-Waehrung ID (Standard: EUR b7d2554b0ce847cd82f3ac9bd1c0dfca)
# SHOPWARE_DEFAULT_CURRENCY_ID=b7d2554b0ce847cd82f3ac9bd1c0dfca

# =============================================================================
# Wiki.js Integration (fuer Software-Produkte)
# =============================================================================
# Base-URL ohne trailing slash
WIKIJS_BASE_URL=https://faq.markus-michalski.net

# =============================================================================
# Cache Settings (in Millisekunden)
# =============================================================================
# Kategorien und Properties aendern sich selten (1 Stunde)
CACHE_TTL_CATEGORIES=3600000
CACHE_TTL_PROPERTIES=3600000
# Snippets koennten oefter aktualisiert werden (5 Minuten)
CACHE_TTL_SNIPPETS=300000

# =============================================================================
# Content Profiles (optional)
# =============================================================================
# Pfad zur content-profiles.json (Default: ./content-profiles.json)
# Ohne Datei werden die Built-in Defaults (creative + software) verwendet.
# Vorlage: content-profiles.example.json
# CONTENT_PROFILES_PATH=./content-profiles.json

# =============================================================================
# Logging
# =============================================================================
# Levels: debug, info, warn, error
LOG_LEVEL=info
